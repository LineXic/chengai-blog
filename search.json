---
layout: null
---
{%- assign visible_posts = site.posts | where_exp: "post", "post.hidden != true and post.categories[0] != '传记'" -%}
[
  {% for post in visible_posts %}
    {
      "title"    : "{{ post.title | escape }}",
      "subtitle" : "{{ post.subtitle | escape }}",
      "tags"     : "{{ post.tags | join: ', ' }}",
      "url"      : "{{ site.baseurl }}{{ post.url }}",
      "date"     : "{{ post.date }}"
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]